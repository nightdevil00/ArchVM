#!/bin/bash

GPU="0000:01:00.0"
AUDIO="0000:01:00.1"

if [ "$(cat /sys/bus/pci/devices/$GPU/power/runtime_status)" = "suspended" ]; then
    sudo modprobe nvidia nvidia_modeset nvidia_uvm 2>/dev/null
    echo "on" | sudo tee /sys/bus/pci/devices/$GPU/power/control
    echo "on" | sudo tee /sys/bus/pci/devices/$AUDIO/power/control
    echo "NVIDIA GPU enabled"
else
    sudo modprobe -r nvidia_uvm nvidia_modeset nvidia_drm nvidia 2>/dev/null
    echo "auto" | sudo tee /sys/bus/pci/devices/$GPU/power/control
    echo "auto" | sudo tee /sys/bus/pci/devices/$AUDIO/power/control
    echo "NVIDIA GPU disabled"
fi
