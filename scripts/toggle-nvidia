#!/bin/bash

GPU="0000:01:00.0"
AUDIO="0000:01:00.1"
CONFIG="/boot/limine.conf"
BLACKLIST_PARAMS="modprobe.blacklist=nvidia modprobe.blacklist=nvidia_uvm modprobe.blacklist=nvidia_modeset modprobe.blacklist=nvidia_drm"

# Function to remove blacklist from limine.conf
enable_drivers() {
    echo "Removing blacklist from $CONFIG..."
    # Match the cmdline for the main Omarchy entry (range until next top-level entry /EFI)
    sudo sed -i "/^\/+Omarchy/,/^\/E/ s/cmdline: .*/& /" "$CONFIG"
    for param in $BLACKLIST_PARAMS; do
        sudo sed -i "/^\/+Omarchy/,/^\/E/ s/$param//" "$CONFIG"
    done
    # Cleanup double spaces
    sudo sed -i "/^\/+Omarchy/,/^\/E/ s/  */ /g" "$CONFIG"
    sudo sed -i "/^\/+Omarchy/,/^\/E/ s/ *$//" "$CONFIG"
}

# Function to add blacklist to limine.conf
disable_drivers() {
    echo "Adding blacklist to $CONFIG..."
    # Find the line number of the FIRST cmdline after /+Omarchy
    LINE_NUM=$(grep -n -A 20 "^\/+Omarchy" "$CONFIG" | grep "cmdline:" | head -n 1 | awk -F'[-:]' '{print $1}')
    
    if [ ! -z "$LINE_NUM" ]; then
        # Check if it already has the blacklist
        if ! sed -n "${LINE_NUM}p" "$CONFIG" | grep -q "modprobe.blacklist=nvidia"; then
            sudo sed -i "${LINE_NUM}s/cmdline: .*/& $BLACKLIST_PARAMS/" "$CONFIG"
        fi
    fi
}

run_updates() {
    echo "Updating bootloader and initramfs..."
    echo "y" | sudo limine-update
    sudo mkinitcpio -P
}

# Check if the GPU is physically present on the PCI bus
if [ ! -d "/sys/bus/pci/devices/$GPU" ]; then
    echo "NVIDIA GPU is currently powered OFF (D3cold). Enabling..."
    
    # 1. Run updates first (in case they regenerate config)
    run_updates
    
    # 2. Update config after regeneration
    enable_drivers
    
    # 3. Rescan the PCI bus
    echo 1 | sudo tee /sys/bus/pci/rescan > /dev/null
    sleep 1
    
    if [ -d "/sys/bus/pci/devices/$GPU" ]; then
        echo "on" | sudo tee /sys/bus/pci/devices/$GPU/power/control > /dev/null
        echo "on" | sudo tee /sys/bus/pci/devices/$AUDIO/power/control > /dev/null
        
        # 4. Load the drivers
        sudo modprobe nvidia nvidia_modeset nvidia_uvm nvidia_drm 2>/dev/null
        echo "NVIDIA GPU enabled, unblacklisted, and powered ON."
    else
        echo "Error: Failed to re-enable NVIDIA GPU via PCI rescan."
    fi
else
    echo "NVIDIA GPU is currently present. Disabling and blacklisting (D3cold)..."
    
    # 1. Unload drivers
    sudo modprobe -r nvidia_uvm nvidia_modeset nvidia_drm nvidia 2>/dev/null
    
    # 2. Run updates first
    run_updates
    
    # 3. Update config after regeneration
    disable_drivers
    
    # 4. Set power control to 'auto' and remove
    echo "auto" | sudo tee /sys/bus/pci/devices/$GPU/power/control > /dev/null
    echo "auto" | sudo tee /sys/bus/pci/devices/$AUDIO/power/control > /dev/null
    echo 1 | sudo tee /sys/bus/pci/devices/$GPU/remove > /dev/null
    echo 1 | sudo tee /sys/bus/pci/devices/$AUDIO/remove > /dev/null
    
    echo "NVIDIA GPU blacklisted, disabled, and removed (True Power Off)."
fi
