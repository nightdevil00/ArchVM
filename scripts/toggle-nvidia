#!/bin/bash

case "$1" in
    enable)
        echo "Enabling NVIDIA blacklist..."
        sudo sed -i 's/rootfstype=btrfs$/rootfstype=btrfs modprobe.blacklist=nvidia modprobe.blacklist=nvidia_uvm modprobe.blacklist=nvidia_modeset/' /boot/limine.conf
        echo -e "blacklist nvidia\nblacklist nvidia_uvm\nblacklist nvidia_modeset\ninstall nvidia /bin/true\ninstall nvidia_uvm /bin/true\ninstall nvidia_modeset /bin/true" | sudo tee /etc/modprobe.d/nvidia-blacklist.conf > /dev/null
        echo "NVIDIA blacklist enabled. Reboot to apply."
        ;;
    disable)
        echo "Disabling NVIDIA blacklist..."
        sudo sed -i 's/ modprobe.blacklist=nvidia modprobe.blacklist=nvidia_uvm modprobe.blacklist=nvidia_modeset//g' /boot/limine.conf
        sudo rm -f /etc/modprobe.d/nvidia-blacklist.conf
        echo "NVIDIA blacklist disabled. Reboot to apply."
        ;;
    status)
        if grep -q "modprobe.blacklist=nvidia" /boot/limine.conf; then
            echo "NVIDIA blacklist: ENABLED"
        else
            echo "NVIDIA blacklist: DISABLED"
        fi
        ;;
    *)
        echo "Usage: $0 {enable|disable|status}"
        exit 1
        ;;
esac
